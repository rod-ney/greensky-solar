# Greensky Solar — environment template
#
# Local dev: copy to ".env.local" (Next.js loads it automatically).
# Vercel: Project → Settings → Environment Variables → "Import" (or paste).
#         Use your production DATABASE_URL and secrets; do not commit .env.local.

# Required on Vercel (build/runtime will fail without a real DB URL)
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE

# Optional: log verbosity (debug, info, warn, error)
# LOG_LEVEL=info

# Upstash Redis (optional — rate limiting in production)
# https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Sentry (optional — error tracking & source maps)
# https://sentry.io/ — Client Keys (DSN), Auth Tokens for uploads
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# Local seed script only (not required on Vercel)
# SEED_DEFAULT_PASSWORD=
